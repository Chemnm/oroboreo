# ============================================================================
# OROBOREO - AI Provider Configuration
# ============================================================================
#
# Choose your AI provider (one of four options):
#   - bedrock: AWS Bedrock (requires AWS account)
#   - foundry: Microsoft Foundry (requires Azure account with AI credits)
#   - anthropic: Anthropic API with pay-as-you-go credits
#   - subscription: Claude Code subscription (uses your claude.ai account)
#
# Copy this file to .env and fill in credentials for your chosen provider:
#   cp .env.example .env
#
# ============================================================================

# AI Provider Selection (bedrock, foundry, anthropic, subscription, or aider)
AI_PROVIDER=subscription

# ============================================================================
# OPTION 1: AWS Bedrock
# ============================================================================
# Required if AI_PROVIDER=bedrock
# See: https://code.claude.com/docs/en/amazon-bedrock
#
# PREREQUISITES:
#   1. AWS Account with Bedrock access enabled
#   2. IAM user with `bedrock:InvokeModel` permission
#   3. Claude models enabled in Bedrock (us-east-1 recommended)
#
# HOW TO GET CREDENTIALS:
#   1. Go to AWS Console → IAM → Users
#   2. Create or select a user
#   3. Create access key (CLI use case)
#   4. Copy the values below
#
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# OPTION 2: Microsoft Foundry (Azure AI)
# ============================================================================
# Required if AI_PROVIDER=foundry
# See: https://platform.claude.com/docs/en/build-with-claude/claude-in-microsoft-foundry
#
# PREREQUISITES:
#   1. Active Azure subscription
#   2. Azure AI Foundry resource created
#   3. Claude model deployment created (claude-opus-4-6, claude-sonnet-4-5, etc.)
#
# HOW TO GET CREDENTIALS:
#   1. Go to Azure Portal → AI Foundry (https://ai.azure.com/)
#   2. Create or select a Foundry resource
#   3. Go to Models + endpoints → Deploy a Claude model
#   4. Go to Keys and Endpoint section
#   5. Copy the API key and resource name below
#
# REGIONS: Claude is available as Global Standard deployment
#
# ============================================================================

ANTHROPIC_FOUNDRY_API_KEY=

# Model-specific resources (each Claude model needs its own deployment):
ANTHROPIC_FOUNDRY_RESOURCE_OPUS=my-opus-deployment
ANTHROPIC_FOUNDRY_RESOURCE_SONNET=my-sonnet-deployment
ANTHROPIC_FOUNDRY_RESOURCE_HAIKU=my-haiku-deployment

# OR use a single resource if you only deployed one model:
# ANTHROPIC_FOUNDRY_RESOURCE=my-foundry-resource

# OR use base URLs instead of resource names:
# ANTHROPIC_FOUNDRY_BASE_URL_OPUS=https://my-opus.services.ai.azure.com/anthropic
# ANTHROPIC_FOUNDRY_BASE_URL_SONNET=https://my-sonnet.services.ai.azure.com/anthropic
# ANTHROPIC_FOUNDRY_BASE_URL_HAIKU=https://my-haiku.services.ai.azure.com/anthropic

# ============================================================================
# OPTION 3: Anthropic API (Pay-As-You-Go)
# ============================================================================
# Required if AI_PROVIDER=anthropic
#
# HOW TO GET API KEY:
#   1. Go to https://console.anthropic.com/
#   2. Create account or sign in
#   3. Go to API Keys section
#   4. Create a new API key
#   5. Copy the key below (starts with sk-ant-)
#   6. Add credits at https://console.anthropic.com/settings/billing
#
# ============================================================================

ANTHROPIC_API_KEY=

# ============================================================================
# OPTION 4: Claude Code Subscription (Recommended for Individuals)
# ============================================================================
# Required if AI_PROVIDER=subscription
#
# PREREQUISITES:
#   1. Active Claude Pro or Team subscription via https://claude.ai/
#   2. Logged into Claude Code CLI (one-time setup)
#
# HOW TO SETUP:
#   1. Subscribe at https://claude.ai/settings/billing
#   2. Run: npx @anthropic-ai/claude-code login
#   3. Follow authentication flow in browser
#   4. Set AI_PROVIDER=subscription in this file
#   5. Leave ANTHROPIC_API_KEY blank
#
# BENEFITS:
#   - No API key management needed
#   - Uses your existing Claude subscription limits
#   - Simpler setup for individual developers
#
# NOTE: No additional configuration needed in this file for subscription mode!
#
# ============================================================================

# ============================================================================
# OPTION 5: Aider (Azure OpenAI, OpenAI, or Local Ollama)
# ============================================================================
# Required if AI_PROVIDER=aider
#
# Aider is an open-source coding agent that supports 100+ models via LiteLLM.
# Use this when you can't access Claude directly (e.g. using Azure OpenAI credits
# or running local models on Nvidia hardware).
#
# PREREQUISITES:
#   pip install aider-chat
#
# THREE-TIER MODEL ROUTING (recommended):
#   Set per-tier models to get smart routing like Claude Opus/Sonnet/Haiku.
#   If per-tier vars are not set, AIDER_MODEL is used for all tiers.
#
# AZURE OPENAI SETUP:
#   1. Azure Portal → Azure OpenAI → your resource
#   2. Keys and Endpoint → copy Key 1 and Endpoint URL
#   3. Azure OpenAI Studio → Deployments → create GPT-4o, GPT-4o-mini, o3-mini
#   4. Use your deployment name in the model strings below (e.g. azure/gpt-4o)
#
# ============================================================================

# Azure OpenAI credentials (required if using azure/* models)
# AZURE_API_KEY=your-azure-openai-key
# AZURE_API_BASE=https://your-resource-name.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

# Per-tier model routing (recommended - mirrors Opus/Sonnet/Haiku routing)
# AIDER_MODEL_OPUS=azure/o3-mini          # Planning tasks (smartest)
# AIDER_MODEL_SONNET=azure/gpt-4o         # [COMPLEX] tasks
# AIDER_MODEL_HAIKU=azure/gpt-4o-mini     # [SIMPLE] tasks (fastest/cheapest)

# OR: single model for all tiers (simpler setup)
# AIDER_MODEL=azure/gpt-4o

# OR: local Ollama (for Nvidia hardware)
# AIDER_MODEL_OPUS=ollama/qwen2.5-coder:32b
# AIDER_MODEL_SONNET=ollama/qwen2.5-coder:14b
# AIDER_MODEL_HAIKU=ollama/qwen2.5-coder:7b

# OR: OpenAI direct
# AIDER_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ============================================================================
# GIT & PULL REQUEST CONFIGURATION
# ============================================================================
#
# Controls automatic git operations after Oroboreo sessions complete.
# All values are optional - defaults shown below.
#
# ============================================================================

# Auto-commit changes to branch after archive (default: true)
GIT_AUTO_COMMIT=true

# Auto-create pull request after successful session (default: true)
# Requires: GitHub CLI (gh) installed and authenticated
GIT_AUTO_CREATE_PR=true

# Auto-merge PR to main after creation (default: false)
# WARNING: Bypasses code review! Only use for personal/dev projects.
# Requires: GIT_AUTO_CREATE_PR=true AND GIT_ALLOW_AUTO_MERGE=true
GIT_AUTO_MERGE=false

# Safety flag to allow auto-merge (default: false)
# Must be explicitly set to true to enable GIT_AUTO_MERGE
GIT_ALLOW_AUTO_MERGE=false

# PR base branch (default: main)
GIT_BASE_BRANCH=main

# PR title format - {sessionName} is replaced with session name (default: Oroboreo: {sessionName})
# GIT_PR_TITLE_FORMAT=Oroboreo: {sessionName}
